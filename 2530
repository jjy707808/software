t=list(map(int,input().split()))
d=int(input())
z=0                 #시간
x=int(d/60)         #분
y=d%60              #초
if x>=60:
    z=int(x/60)
    x=x%60
t[0]=t[0]+z
t[1]=t[1]+x
t[2]=t[2]+y
for i in range(2,0,-1):
    if t[i]>=60:
        t[i-1]=t[i-1]+int(t[i]/60)
        t[i]=t[i]%60
if t[0]>=24:
    t[0]=t[0]%24
print(*t)
