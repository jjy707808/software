a=int(input())
x=[]
for i in range(1,a*2+1):
    if i%2==0:
        for i in range(1,a+1):
            if i%2==0:
                x.append("*")
            else:
                x.append(" ")
        print("".join(x))
        x=[]
    else:
        for i in range(1,a+1):
            if i%2==0:
                x.append(" ")
            else:
                x.append("*")
        print("".join(x))
        x=[]
